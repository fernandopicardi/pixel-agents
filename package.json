{
  "name": "agent-craft",
  "displayName": "AgentCraft",
  "description": "Pixel art office where your Claude Code agents come to life as animated characters — works in VS Code and Cursor IDE",
  "version": "2.0.0",
  "publisher": "fernandopicardi",
  "repository": {
    "type": "git",
    "url": "https://github.com/fernandopicardi/agent-craft"
  },
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "pixel-art",
    "claude",
    "ai-agents",
    "cursor",
    "cursor-ide",
    "vscode",
    "claude-code"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agent-craft.showPanel",
        "title": "AgentCraft: Show Panel"
      },
      {
        "command": "agent-craft.exportDefaultLayout",
        "title": "AgentCraft: Export Layout as Default"
      },
      {
        "command": "agent-craft.enterLicenseKey",
        "title": "AgentCraft: Enter License Key"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "agent-craft-panel",
          "title": "AgentCraft",
          "icon": "$(window)"
        }
      ]
    },
    "views": {
      "agent-craft-panel": [
        {
          "type": "webview",
          "id": "agent-craft.panelView",
          "name": "AgentCraft"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:webview": "cd webview-ui && npm run build",
    "compile": "npm run check-types && npm run lint && node esbuild.js && npm run build:webview",
    "build": "npm run compile",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run build:webview",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "import-tileset": "tsx scripts/import-tileset-cli.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@types/node": "22.x",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
